# MongoDB Configuration
VITE_MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/?appName=YourApp
VITE_MONGODB_DB_NAME=trolley

# API Configuration (for production)
